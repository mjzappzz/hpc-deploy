[Unit]
Description=HPCDeploy FastAPI Backend
After=network.target

[Service]
Type=simple
User=REPLACED_BY_INSTALL_SCRIPT
Group=REPLACED_BY_INSTALL_SCRIPT
WorkingDirectory=REPLACED_BY_INSTALL_SCRIPT/backend
Environment=PYTHONPATH=REPLACED_BY_INSTALL_SCRIPT/backend/.deps:REPLACED_BY_INSTALL_SCRIPT/backend
ExecStart=REPLACED_BY_INSTALL_SCRIPT/backend/.deps/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
