[Unit]
Description=HPCDeploy FastAPI Backend
After=network.target

[Service]
Type=simple
User=tjzs
Group=tjzs
WorkingDirectory=/home/tjzs/projects/hpc-deploy/backend
Environment=PYTHONPATH=/home/tjzs/projects/hpc-deploy/backend/.deps:/home/tjzs/projects/hpc-deploy/backend
ExecStart=/home/tjzs/projects/hpc-deploy/backend/.deps/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
